# Exchange
EXCHANGE_ID=binance
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
USE_TESTNET=True

# Trading
SYMBOL=BTC/USDT
TIMEFRAME=1h
TRADE_AMOUNT_USDT=10

# Strategy
EMA_SHORT=9
EMA_LONG=21
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30

# Risk management
MAX_POSITION_SIZE=0.02
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.04

# Bot settings
LOOP_INTERVAL_SECONDS=60
LOG_FILE=trading.log

# Telegram (optional — leave blank to disable)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
